# mock keeps local development deterministic. Use x402 when a real wallet/facilitator is configured.
PAYMENTS_MODE=mock
PORT=3000

# Required when PAYMENTS_MODE=x402.
X402_PAY_TO=0xYourWalletAddress
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_MAX_TIMEOUT_SECONDS=60
